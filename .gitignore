# Godot 4+ specific ignores
.godot/
/android/

# Build / export output
/export/
export_presets.cfg.bak

# Local npm cache (used when global cache is unavailable in sandboxed sessions)
.npm-cache/
reference/html-proto/.npm-cache/

# Editor / OS noise
*.tmp
*.import.bak
.DS_Store
Thumbs.db

# Claude Code per-user local settings (permission grants, etc.).
# Project-shared Claude settings (.claude/settings.json) ARE committable.
.claude/settings.local.json

# Claude Code worktrees (each holds a full repo copy — never commit).
.claude/worktrees/

# Art-skill-eval working dir: generated candidate PNGs, upscales, per-run logs.
# WIP art is kept local (same convention as card art.png); the experiment
# record reaches the user via image attachments. Curated results can be
# committed selectively later if we decide to keep them in-repo.
art-eval/**/judge/
art-eval/**/_meta/
